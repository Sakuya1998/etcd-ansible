ETCD_SNAPSHOT_BACKEND={{ etcd_snapshot_backend }}
ETCD_SNAPSHOT_PREFIX={{ etcd_snapshot_prefix }}

# S3/MinIO
ETCD_SNAPSHOT_S3_BUCKET={{ etcd_snapshot_s3_bucket }}
ETCD_SNAPSHOT_S3_ENDPOINT_URL={{ etcd_snapshot_s3_endpoint_url }}
ETCD_SNAPSHOT_S3_REGION={{ etcd_snapshot_s3_region }}
AWS_ACCESS_KEY_ID={{ etcd_snapshot_s3_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ etcd_snapshot_s3_secret_access_key }}

# OSS
ETCD_SNAPSHOT_OSS_BUCKET={{ etcd_snapshot_oss_bucket }}
ETCD_SNAPSHOT_OSS_ENDPOINT={{ etcd_snapshot_oss_endpoint }}
ETCD_SNAPSHOT_OSS_ACCESS_KEY_ID={{ etcd_snapshot_oss_access_key_id }}
ETCD_SNAPSHOT_OSS_ACCESS_KEY_SECRET={{ etcd_snapshot_oss_access_key_secret }}

# NFS（脚本会把快照复制到该目录；也可以让 etcd_backup_dir 本身就是 NFS mount）
ETCD_SNAPSHOT_NFS_DIR={{ etcd_snapshot_nfs_dir }}

